{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 800,
  "height": 400,
  "signals": [
    {
      "name": "groupField",
      "value": "sample",
      "bind": {"input": "select", "options": [], "name": "Group by: "}
    },
    {
      "name": "metricField",
      "value": "observed_features",
      "bind": {"input": "select", "options": [], "name": "Metric: "}
    },
    {
      "name": "knee_point",
      "update": "length(data('selected_knee')) > 0 ? data('selected_knee')[0].knee : null"
    }
  ],
  "data": [
    {"name": "raw", "values": []},
    {
      "name": "raw_filtered",
      "source": "raw",
      "transform": [
        {"type": "filter", "expr": "metricField && datum.metric === metricField"},
        {"type": "formula", "as": "group", "expr": "groupField && metricField ? datum[groupField] : datum.sample"},
        {"type": "formula", "as": "observed", "expr": "datum.observed"}
      ]
    },
    {
      "name": "stats",
      "source": "raw_filtered",
      "transform": [
        {
          "type": "aggregate",
          "groupby": ["group", "read_depth"],
          "ops": ["median", "q1", "q3", "min", "max"],
          "fields": ["observed", "observed", "observed", "observed", "observed"],
          "as": ["median", "q1", "q3", "min", "max"]
        }
      ]
    },
    {"name": "knee_points", "values": []},
    {
      "name": "selected_knee",
      "source": "knee_points",
      "transform": [{"type": "filter", "expr": "datum.metric === metricField"}]
    },
    {"name": "samples", "values": []},
    {
      "name": "samples_flat",
      "source": "samples",
      "transform": [
        {"type": "flatten", "fields": ["all_depths"], "as": ["depth"]},
        {"type": "formula", "as": "group", "expr": "datum[groupField]"},
        {"type": "filter", "expr": "datum.reads >= datum.depth"}
      ]
    },
    {
      "name": "samples_at_depth",
      "source": "samples_flat",
      "transform": [
        {
          "type": "aggregate",
          "groupby": ["group", "depth"],
          "ops": ["count"],
          "as": ["sample_count"]
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "color",
      "type": "ordinal",
      "domain": {"data": "raw_filtered", "field": "group"},
      "range": {"scheme": "category10"}
    }
  ],
  "marks": [
    {
      "type": "group",
      "name": "upper_plot",
      "encode": {
        "enter": {
          "x": {"value": 5},
          "y": {"value": 75},
          "width": {"value": 800},
          "height": {"value": 400}
        }
      },
      "scales": [
        {
          "name": "x1",
          "type": "linear",
          "domain": {"data": "raw_filtered", "field": "read_depth"},
          "range": "width"
        },
        {
          "name": "y1",
          "type": "linear",
          "domain": {"data": "raw_filtered", "field": "observed"},
          "range": "height"
        }
      ],
      "axes": [
        {"scale": "x1", "orient": "bottom", "title": "Sequencing Depth"},
        {"scale": "y1", "orient": "left", "title": {"signal": "metricField"}}
      ],
      "marks": [
        {
          "type": "rect",
          "from": {"data": "stats"},
          "encode": {
            "update": {
              "x": {"scale": "x1", "field": "read_depth", "offset": -6},
              "x2": {"scale": "x1", "field": "read_depth", "offset": 6},
              "y": {"scale": "y1", "field": "q3"},
              "y2": {"scale": "y1", "field": "q1"},
              "stroke": {"scale": "color", "field": "group"},
              "fill": {"value": null}
            }
          }
        },
        {
          "type": "rule",
          "from": {"data": "stats"},
          "encode": {
            "update": {
              "x": {"scale": "x1", "field": "read_depth"},
              "y": {"scale": "y1", "field": "min"},
              "y2": {"scale": "y1", "field": "max"},
              "stroke": {"scale": "color", "field": "group"}
            }
          }
        },
        {
          "type": "group",
          "from": {
            "facet": {
              "name": "faceted_lines",
              "data": "stats",
              "groupby": "group"
            }
          },
          "marks": [
            {
              "type": "line",
              "from": {"data": "faceted_lines"},
              "encode": {
                "update": {
                  "x": {"scale": "x1", "field": "read_depth"},
                  "y": {"scale": "y1", "field": "median"},
                  "stroke": {"scale": "color", "field": "group"},
                  "strokeWidth": {"value": 1}
                }
              }
            }
          ]
        },
        {
          "type": "rule",
          "encode": {
            "enter": {
              "y": {"value": 0},
              "y2": {"signal": "height"},
              "stroke": {"value": "red"},
              "strokeWidth": {"value": 2}
            },
            "update": {"x": {"scale": "x1", "signal": "knee_point"}}
          }
        }
      ]
    },
    {
      "type": "group",
      "name": "lower_plot",
      "encode": {
        "enter": {
          "x": {"value": 5},
          "y": {"value": 550},
          "width": {"value": 800},
          "height": {"value": 400}
        }
      },
      "scales": [
        {
          "name": "x2",
          "type": "linear",
          "domain": {"data": "raw_filtered", "field": "read_depth"},
          "nice": true,
          "range": "width"
        },
        {
          "name": "y2",
          "type": "linear",
          "domain": {"data": "samples_at_depth", "field": "sample_count"},
          "nice": true,
          "range": "height"
        }
      ],
      "axes": [
        {"scale": "x2", "orient": "bottom", "title": "Read Depth"},
        {"scale": "y2", "orient": "left", "title": "Number of Samples"}
      ],
      "marks": [
        {
          "type": "group",
          "from": {
            "facet": {
              "name": "faceted_lower",
              "data": "samples_at_depth",
              "groupby": "group"
            }
          },
          "marks": [
            {
              "type": "line",
              "from": {"data": "faceted_lower"},
              "encode": {
                "update": {
                  "x": {"scale": "x2", "field": "depth"},
                  "y": {"scale": "y2", "field": "sample_count"},
                  "stroke": {"scale": "color", "field": "group"},
                  "strokeWidth": {"value": 1}
                }
              }
            },
            {
              "type": "symbol",
              "from": {"data": "faceted_lower"},
              "encode": {
                "update": {
                  "x": {"scale": "x2", "field": "depth"},
                  "y": {"scale": "y2", "field": "sample_count"},
                  "fill": {"scale": "color", "field": "group"},
                  "size": {"value": 20}
                }
              }
            }
          ]
        }
      ]
    }
  ],
  "legends": [
    {
      "fill": "color",
      "title": "Group",
      "orient": "bottom",
      "encode": {
        "symbols": {"update": {"size": {"value": 100}}},
        "labels": {"update": {"fontSize": {"value": 12}}}
      }
    }
  ],
  "config": {}
}