    {
      "name": "samples_with_group",
      "source": "samples",
      "transform": [
        {
          "type": "formula",
          "as": "group",
          "expr": "datum[groupField]"
        }
      ]
    },
    {
      "name": "counts",
      "source": "samples_with_group",
      "transform": [
        {
          "type": "aggregate",
          "groupby": [
            "group",
            "reads"
          ],
          "ops": [
            "count"
          ],
          "as": [
            "count"
          ]
        }
      ]
    },
    {
      "name": "sorted",
      "source": "counts",
      "transform": [
        {
          "type": "collect",
          "sort": {
            "field": [
              "group",
              "reads"
            ],
            "order": [
              "ascending",
              "descending"
            ]
          }
        }
      ]
    },
    {
      "name": "cumulative",
      "source": "sorted",
      "transform": [
        {
          "type": "window",
          "groupby": [
            "group"
          ],
          "ops": [
            "sum"
          ],
          "fields": [
            "count"
          ],
          "as": [
            "samples_geq_reads"
          ]
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "x",
      "type": "linear",
      "domain": {
        "data": "samples",
        "field": "reads"
      },
      "nice": true,
      "range": "width"
    },
    {
      "name": "y",
      "type": "linear",
      "domain": {
        "data": "cumulative",
        "field": "samples_geq_reads"
      },
      "nice": true,
      "range": "height"
    },
    {
      "name": "color",
      "type": "ordinal",
      "domain": {
        "data": "samples_with_group",
        "field": "group"
      },
      "range": {
        "scheme": "category10"
      }
    }
  ],
  "axes": [
    {
